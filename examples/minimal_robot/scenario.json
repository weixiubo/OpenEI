{
  "name": "minimal-robot-workbench",
  "robot": "robot.yaml",
  "provider": "rule",
  "audit_log": "logs/minimal_robot_audit.jsonl",
  "adapter": {
    "type": "custom",
    "path": "adapter.py",
    "class": "MinimalRobotAdapter"
  },
  "skill_packages": ["skills"],
  "task": {
    "text": "执行参考机器人问候",
    "parameters": {
      "skill": "minimal.wave",
      "duration_seconds": 4,
      "tags": ["sample-action"]
    },
    "expected_result": "参考机器人完成问候并回到安全姿态"
  },
  "expect": {
    "success": true,
    "contains_skills": ["minimal.wave", "minimal.safe_stand"],
    "message_contains": "任务已完成"
  }
}
